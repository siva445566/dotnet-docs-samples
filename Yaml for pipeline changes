trigger: none

parameters:
  - name: SecretNames
    displayName: "Existing Secret Name(s) - comma separated (e.g. secret1,secret2,secret3)"
    type: string
    default: ""

  - name: NewSecretNames
    displayName: "New Secret Name(s) - same order as above (e.g. new1,new2,new3)"
    type: string
    default: ""

variables:
  - group: KeyVault-VarGroup   # Must contain variable: VaultName

pool:
  vmImage: "windows-latest"

steps:
  - task: AzurePowerShell@5
    displayName: "Install Az Modules If Missing"
    inputs:
      azureSubscription: "<YOUR_SERVICE_CONNECTION_NAME>"
      ScriptType: InlineScript
      Inline: |
        if (-not (Get-Module -ListAvailable -Name Az.KeyVault)) {
            Write-Host "Az.KeyVault not found. Installing..." -ForegroundColor Yellow
            Install-Module -Name Az.KeyVault  -Scope CurrentUser -Force -AllowClobber
            Install-Module -Name Az.Accounts -Scope CurrentUser -Force -AllowClobber
        } else {
            Write-Host "Az modules already available." -ForegroundColor Green
        }
      azurePowerShellVersion: LatestVersion
      pwsh: true

  - task: AzurePowerShell@5
    displayName: "Rename Key Vault Secrets (No Versioning)"
    inputs:
      azureSubscription: "<YOUR_SERVICE_CONNECTION_NAME>"
      ScriptType: FilePath
      ScriptPath: "$(Build.SourcesDirectory)/scripts/Rename-KeyVaultSecrets.ps1"
      ScriptArguments: >
        -VaultName "$(VaultName)"
        -SecretNames "${{ parameters.SecretNames }}"
        -NewSecretNames "${{ parameters.NewSecretNames }}"
      azurePowerShellVersion: LatestVersion
      pwsh: true
