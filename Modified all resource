param(
   [Parameter(Mandatory=$true)][ValidateSet("dev","uat","prod")][string]$Environment,
   [Parameter(Mandatory=$true)][ValidateSet("storage","keyvault","sql")][string]$ResourceType,
   [string]$IPAddress   = "",
   [string]$CIDRSuffix  = "",
   [string]$SQLStartIP  = "",
   [string]$SQLEndIP    = "",
   [string]$RuleName    = ""
)

# ---- Resource Map from Variable Group env vars ----
$r = @{
   RG      = (Get-Variable "${Environment}_RESOURCE_GROUP"         -ValueOnly -ErrorAction SilentlyContinue) ?? $env:("${Environment}_RESOURCE_GROUP".ToUpper())
   Storage = [System.Environment]::GetEnvironmentVariable("${Environment}_STORAGE_ACCOUNT_NAME".ToUpper())
   KV      = [System.Environment]::GetEnvironmentVariable("${Environment}_KEYVAULT_NAME".ToUpper())
   SQL     = [System.Environment]::GetEnvironmentVariable("${Environment}_SQL_SERVER_NAME".ToUpper())
}

# Cleaner env var reader
function Env($key) { [System.Environment]::GetEnvironmentVariable($key.ToUpper()) }

$RG      = Env "${Environment}_RESOURCE_GROUP"
$Storage = Env "${Environment}_STORAGE_ACCOUNT_NAME"
$KV      = Env "${Environment}_KEYVAULT_NAME"
$SQL     = Env "${Environment}_SQL_SERVER_NAME"

Write-Host "Environment: $Environment | Resource: $ResourceType | RG: $RG" -ForegroundColor Cyan

# ---- CIDR Helper ----
function Get-CIDR($ip, $suffix) {
   if ($ip -match "/\d+$") { return $ip }
   if ($suffix)             { return "$ip/$($suffix.TrimStart('/'))" }
   Write-Host "No CIDR provided, defaulting to /32" -ForegroundColor Yellow
   return "$ip/32"
}

# ---- Auto rule name for SQL ----
function New-RuleName($ip) {
   "fw-$(($ip -replace '[./]','-'))-$(Get-Date -Format 'yyyyMMdd-HHmm')"
}

# ---- MAIN ----
switch ($ResourceType.ToLower()) {

   "storage" {
       if (-not $IPAddress) { Write-Error "IPAddress required for Storage"; exit 1 }
       $cidr = Get-CIDR $IPAddress $CIDRSuffix
       Write-Host "Adding $cidr to Storage: $Storage"

       $existing = (Get-AzStorageAccount -ResourceGroupName $RG -Name $Storage).NetworkRuleSet.IpRules
       if ($existing.IPAddressOrRange -contains $cidr) {
           Write-Host "Rule already exists. Skipping." -ForegroundColor Yellow; exit 0
       }
       Add-AzStorageAccountNetworkRule -ResourceGroupName $RG -Name $Storage -IPAddressOrRange $cidr
       Write-Host "Done." -ForegroundColor Green
   }

   "keyvault" {
       if (-not $IPAddress) { Write-Error "IPAddress required for KeyVault"; exit 1 }
       $cidr = Get-CIDR $IPAddress $CIDRSuffix
       Write-Host "Adding $cidr to KeyVault: $KV"

       $existing = (Get-AzKeyVault -ResourceGroupName $RG -VaultName $KV).NetworkAcls.IpAddressRanges
       if ($existing -contains $cidr) {
           Write-Host "Rule already exists. Skipping." -ForegroundColor Yellow; exit 0
       }
       Add-AzKeyVaultNetworkRule -ResourceGroupName $RG -VaultName $KV -IpAddressRange $cidr
       Write-Host "Done." -ForegroundColor Green
   }

   "sql" {
       if (-not $SQLStartIP -or -not $SQLEndIP) {
           Write-Error "SQLStartIP and SQLEndIP both required for SQL"; exit 1
       }
       if (-not $RuleName) { $RuleName = New-RuleName $SQLStartIP }
       Write-Host "Adding rule '$RuleName' [$SQLStartIP -> $SQLEndIP] to SQL: $SQL"

       $exists = Get-AzSqlServerFirewallRule -ResourceGroupName $RG -ServerName $SQL -FirewallRuleName $RuleName -ErrorAction SilentlyContinue
       if ($exists) {
           Set-AzSqlServerFirewallRule -ResourceGroupName $RG -ServerName $SQL -FirewallRuleName $RuleName -StartIpAddress $SQLStartIP -EndIpAddress $SQLEndIP
           Write-Host "Rule updated." -ForegroundColor Green
       } else {
           New-AzSqlServerFirewallRule -ResourceGroupName $RG -ServerName $SQL -FirewallRuleName $RuleName -StartIpAddress $SQLStartIP -EndIpAddress $SQLEndIP
           Write-Host "Rule created." -ForegroundColor Green
       }
   }

   default { Write-Error "Invalid ResourceType. Use: storage, keyvault, sql"; exit 1 }
}
