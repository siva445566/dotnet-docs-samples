parameters:
  - name: Environment
    displayName: 'Select Environment'
    type: string
    values:
      - dev
      - test
      - uat
      - preprod
      - prod

  - name: SecretNames
    displayName: 'Secret Name(s) to Recover (comma-separated)'
    type: string

stages:
  - stage: RecoverSecrets
    displayName: 'Recover Secrets [${{ parameters.Environment }}]'
    jobs:
      - job: RecoverJob
        displayName: 'Recover Deleted Secrets'
        pool:
          vmImage: 'windows-latest'
        steps:

          # ── Step 1: Resolve subscription and vault based on environment ──
          - task: PowerShell@2
            displayName: 'Set Environment Variables'
            inputs:
              targetType: 'inline'
              script: |
                $env = "${{ parameters.Environment }}"

                switch ($env) {
                  "dev" {
                    $sub   = "azuresub-dev"
                    $vault = "azure-devkey"
                  }
                  { $_ -in "test", "uat" } {
                    $sub   = "azuresub-test"
                    $vault = "azure-testkey"
                  }
                  { $_ -in "preprod", "prod" } {
                    $sub   = "azure-prod"
                    $vault = "azure-prodkey"
                  }
                  default {
                    Write-Host "##vso[task.logissue type=error]Unknown environment: $env"
                    exit 1
                  }
                }

                Write-Host "##vso[task.setvariable variable=azureSubscription]$sub"
                Write-Host "##vso[task.setvariable variable=keyVaultName]$vault"

                Write-Host "[OK] Environment  : $env"  -ForegroundColor Green
                Write-Host "[OK] Subscription : $sub"  -ForegroundColor Green
                Write-Host "[OK] Key Vault    : $vault" -ForegroundColor Green

          # ── Step 2: Use resolved variables in the actual task ────────────
          - task: AzurePowerShell@5
            displayName: 'Recover Deleted Secrets - ${{ parameters.Environment }}'
            inputs:
              azureSubscription: '$(azureSubscription)'
              ScriptType: 'FilePath'
              ScriptPath: '$(System.DefaultWorkingDirectory)/Recover-KeyVaultSecrets.ps1'
              ScriptArguments: >
                -VaultName "$(keyVaultName)"
                -SecretNames "${{ parameters.SecretNames }}"
              azurePowerShellVersion: 'LatestVersion'
