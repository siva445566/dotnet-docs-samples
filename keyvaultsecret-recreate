param(
    [Parameter(Mandatory=$true)]
    [string]$VaultName
)

# Ensure you're logged in
$context = Get-AzContext
if (-not $context) {
    Write-Host "Please login to Azure..." -ForegroundColor Yellow
    Connect-AzAccount
}

Write-Host "`nFetching secrets from '$VaultName'..." -ForegroundColor Cyan
$secrets = Get-AzKeyVaultSecret -VaultName $VaultName

if (-not $secrets) {
    Write-Host "No secrets found in vault '$VaultName'" -ForegroundColor Red
    exit
}

$secretDetails = @()

foreach ($secret in $secrets) {
    $secretInfo = Get-AzKeyVaultSecret -VaultName $VaultName -Name $secret.Name

    # Convert SecureString safely
    $value = [System.Runtime.InteropServices.Marshal]::PtrToStringAuto(
        [System.Runtime.InteropServices.Marshal]::SecureStringToBSTR($secretInfo.SecretValue)
    )

    $secretDetails += [PSCustomObject]@{
        Name           = $secret.Name
        Value          = $value
        ContentType    = $secretInfo.ContentType
        ExpirationDate = $secretInfo.Expires
        NotBefore      = $secretInfo.NotBefore
        Enabled        = $secretInfo.Enabled
        Tags           = $secretInfo.Tags
    }

    Write-Host "Secret Name: $($secret.Name)"
}

Write-Host "`n===== SECRET RENAME (NO VERSIONING) =====`n" -ForegroundColor Yellow

while ($true) {

    for ($i = 0; $i -lt $secretDetails.Count; $i++) {
        Write-Host "[$i] $($secretDetails[$i].Name)"
    }

    $selection = Read-Host "`nSelect secret index (or 'q' to quit)"
    if ($selection -eq 'q') { break }

    $index = [int]$selection
    if ($index -lt 0 -or $index -ge $secretDetails.Count) {
        Write-Host "Invalid selection" -ForegroundColor Red
        continue
    }

    $selectedSecret = $secretDetails[$index]

    $newName = Read-Host "Enter NEW secret name"

    # 🚫 Prevent version creation
    $existingSecret = Get-AzKeyVaultSecret -VaultName $VaultName -Name $newName -ErrorAction SilentlyContinue
    if ($existingSecret) {
        Write-Host "❌ Secret '$newName' already exists. Skipping to avoid versioning." -ForegroundColor Red
        continue
    }

    $params = @{
        VaultName   = $VaultName
        Name        = $newName
        SecretValue = (ConvertTo-SecureString -String $selectedSecret.Value -AsPlainText -Force)
    }

    if ($selectedSecret.ContentType) { $params['ContentType'] = $selectedSecret.ContentType }
    if ($selectedSecret.ExpirationDate) { $params['Expires'] = $selectedSecret.ExpirationDate }
    if ($selectedSecret.NotBefore) { $params['NotBefore'] = $selectedSecret.NotBefore }

    if ($selectedSecret.Tags) {
        $tagHash = @{}
        $selectedSecret.Tags.GetEnumerator() | ForEach-Object {
            $tagHash[$_.Key] = $_.Value
        }
        $params['Tag'] = $tagHash
    }

    try {
        Set-AzKeyVaultSecret @params
        Write-Host "✅ New secret '$newName' created (NO version created)" -ForegroundColor Green
    }
    catch {
        Write-Host "❌ Failed: $_" -ForegroundColor Red
    }
}

Write-Host "`nDone." -ForegroundColor Cyan
