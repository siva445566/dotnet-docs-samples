parameters:
  - name: Environment
    displayName: "Environment"
    type: string
    default: "dev"
    values: [dev, test, prod]

  - name: AddStorage
    displayName: "Storage Account"
    type: boolean
    default: false

  - name: AddKeyVault
    displayName: "Key Vault"
    type: boolean
    default: false

  - name: AddSQL
    displayName: "SQL Server"
    type: boolean
    default: false

  - name: IPAddresses
    displayName: "IP Addresses — comma separated e.g. 10.0.0.1, 10.0.0.2/26"
    type: string
    default: " "

  - name: RuleNames
    displayName: "SQL Rule Names — comma separated e.g. rule1,rule2"
    type: string
    default: " "

  - name: StartIPs
    displayName: "SQL Start IPs — comma separated e.g. 10.0.0.1,10.0.0.10"
    type: string
    default: " "

  - name: EndIPs
    displayName: "SQL End IPs — comma separated e.g. 10.0.0.5,10.0.0.15"
    type: string
    default: " "

variables:
  - ${{ if eq(parameters.Environment, 'dev') }}:
    - group: dev-group

trigger: none

stages:
  - stage: FirewallUpdate
    displayName: "Update Firewall Rules - ${{ parameters.Environment }}"
    jobs:
      - job: RunFirewallScript
        displayName: "Add Firewall Rules"
        pool:
          vmImage: "windows-latest"
        steps:
          - checkout: self
          - task: AzurePowerShell@5
            displayName: "Run Firewall IP Whitelisting Script"
            inputs:
              azureSubscription: $(azureServiceConnection)
              ScriptType: FilePath
              ScriptPath: '$(System.DefaultWorkingDirectory)/scripts/ip.ps1'
              ScriptArguments: >
                -AddStorage "${{ parameters.AddStorage }}"
                -AddKeyVault "${{ parameters.AddKeyVault }}"
                -AddSQL "${{ parameters.AddSQL }}"
                -StorageAccountName "$(StorageAccountName)"
                -KeyVaultName "$(KeyVaultName)"
                -SQLServerName "$(SQLServerName)"
                -IPAddresses "${{ parameters.IPAddresses }}"
                -RuleNames "${{ parameters.RuleNames }}"
                -StartIPs "${{ parameters.StartIPs }}"
                -EndIPs "${{ parameters.EndIPs }}"
              azurePowerShellVersion: LatestVersion
              pwsh: true
